# =============================================================================
# Peach Basket — environment variables
# Copy to .env (local) or set in your hosting provider (production).
# =============================================================================

# --- Required ---

# PostgreSQL connection string (Prisma)
# Local: use your machine Postgres URL.
# Supabase + Vercel: use the transaction pooler for runtime (port 6543, pgbouncer=true).
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct/session connection for Prisma migrations (Supabase). Omit for local-only Postgres.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# HMAC secret for admin/organizer portal session cookies (required in production)
PORTAL_SESSION_SECRET="generate-a-long-random-string"

# --- Cron (required in production if vercel.json cron is enabled) ---

# Vercel automatically sends: Authorization: Bearer <CRON_SECRET>
# Generate a long random string; must match hosting provider CRON_SECRET.
CRON_SECRET="generate-a-long-random-string"

# --- Feature flags (server) — default OFF unless noted ---

# Player rating read path. Unset = production Formula v1.
# shadow-vnext = experimental vNext policy reads (do not enable in production without approval)
# PLAYER_RATING_FORMULA_MODE=shadow-vnext
# PLAYER_RATING_FORMULA_MODE=shadow-tier-normalized-v1

# National TPI board on /teams (default: false = competition standings only)
# TEAM_NATIONAL_RATINGS_ENABLED=true

# Team snapshot publish script writes (default: false)
# TEAM_SNAPSHOT_PUBLISH_ENABLED=true

# CLI team TPI recompute script writes (default: false; admin import path is separate)
# TEAM_TPI_RECOMPUTE_ENABLED=true

# National rankings read path (default: false = live PlayerRating + GameStat rebuild)
# RANKINGS_READ_FROM_SNAPSHOTS=1

# Max national boards loaded concurrently (default: 3)
# RANKINGS_BOARD_CONCURRENCY=3

# --- Feature flags (client) ---

# U19 graduation-class filter on /rankings (default: false; auto-on in NODE_ENV=development)
# NEXT_PUBLIC_RECRUITING_CLASS_FILTER_ENABLED=true

# --- Optional / tooling ---

# NODE_ENV is set by the framework (development | production | test)

# Admin preview HTML capture script only
# TR6A_CAPTURE_BASE_URL=http://localhost:3000
